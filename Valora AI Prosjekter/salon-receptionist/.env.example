# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=https://your-ngrok-or-domain.com   # Public URL Twilio/Vapi will hit

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose to clients
SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────
# Twilio (account-level, for number routing)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ─────────────────────────────────────────────
# Vapi.ai
# ─────────────────────────────────────────────
VAPI_API_KEY=your-vapi-api-key
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret   # Used to verify Vapi webhook signatures

# ─────────────────────────────────────────────
# Google Calendar (OAuth 2.0 service account)
# ─────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-gcp-project-id

# ─────────────────────────────────────────────
# 46elks (SMS – Norwegian numbers)
# ─────────────────────────────────────────────
FORTYSIX_ELKS_API_USERNAME=your-46elks-username
FORTYSIX_ELKS_API_PASSWORD=your-46elks-password
FORTYSIX_ELKS_FROM_NUMBER=+47xxxxxxxx   # Registered sender number

# ─────────────────────────────────────────────
# n8n (internal webhook auth)
# ─────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_WEBHOOK_SECRET=your-shared-secret-with-n8n

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
API_SECRET_KEY=your-admin-api-key   # For internal admin routes
