generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Candidate {
  id              String    @id @default(cuid())
  userId          String
  name            String
  role            String
  company         String
  linkedinUrl     String?
  interactionType String
  tags            String[]  @default([])
  signals         Json      @default("{}")
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  status          String    @default("new")
  searchId        String?

  actions           Action[]
  conversationTurns ConversationTurn[]
  search            Search?            @relation(fields: [searchId], references: [id])
}

model Search {
  id                String      @id @default(cuid())
  userId            String
  title             String
  company           String
  rawContext        String?     @db.Text
  structuredContext Json?
  extractionStatus  String      @default("idle")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  candidates        Candidate[]
}

model Action {
  id              String    @id @default(cuid())
  candidateId     String
  messageContent  String
  strategyType    String
  messageVariant  String
  signalsSnapshot Json
  status          String
  replyType       String?
  replyContent    String?
  sentAt          DateTime?
  repliedAt       DateTime?
  createdAt       DateTime  @default(now())
  angle           String?
  tensionType     String?
  keyPhrase       Json?
  outcome         String?

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model ConversationTurn {
  id           String   @id @default(cuid())
  candidateId  String
  turn         Int
  direction    String
  content      String
  strategyType String?
  replyType    String?
  createdAt    DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}
